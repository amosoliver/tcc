<div id="<%= dom_id pessoa %>">
  <p>
    <strong>Nome:</strong>
    <%= pessoa.nome %>
  </p>

  <p>
    <strong>Cpf:</strong>
    <%= pessoa.cpf %>
  </p>

  <p>
    <strong>Data nascimento:</strong>
    <%= pessoa.data_nascimento %>
  </p>

  <p>
    <strong>Telefone:</strong>
    <%= pessoa.telefone %>
  </p>

  <p>
    <strong>Email:</strong>
    <%= pessoa.email %>
  </p>

  <p>
    <strong>Endereco:</strong>
    <%= pessoa.endereco %>
  </p>

</div>
