<%= simple_form_for @cliente do |form| %>
  <% if @cliente.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(@cliente.errors.count, "error") %> prohibited this cliente from being saved:</h2>
      <ul>
        <% @cliente.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.input :id_pessoa, 
                   collection: @pessoas, 
                   label_method: :nome, 
                   value_method: :id, 
                   prompt: "Selecione uma Pessoa" %>
  </div>

  <div>
    <%= form.input :id_tipo_usuario, 
                   collection: @tipos_usuarios, 
                   label_method: :descricao, 
                   value_method: :id, 
                   prompt: "Selecione um Tipo de Usuário" %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
